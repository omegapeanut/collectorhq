rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Card catalog is public read-only data (prices, art, sales history).
    // No client writes: the app itself never writes cards, only the
    // seed script (scripts/seed-firestore.ts) does, run by a maintainer.
    match /cards/{cardId} {
      allow read: if true;
      allow write: if false;
    }

    // Full multi-TCG catalog (name/set/number/rarity/finish/image, no price —
    // price stays a live external reference, per product decision). Public
    // read-only. Writes only via the Admin SDK: scripts/import-catalog.ts for
    // bulk set imports, and the /api/admin/catalog route for one-off adds.
    match /catalog/{cardId} {
      allow read: if true;
      allow write: if false;
    }
    match /catalogSets/{setId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
